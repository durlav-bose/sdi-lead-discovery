# Copy to .env and adjust if needed

# Postgres (docker-compose default)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sdi?schema=public"

# Redis (docker-compose default)
REDIS_URL="redis://localhost:6379"

# Base URL for internal links (used in CSV metadata)
APP_BASE_URL="http://localhost:3000"

# Optional: set to 1 to enable LLM calls (NOT required for dev)
ENABLE_LLM="0"

# Optional LLM provider (Gemini/OpenAI/etc.) - leave empty for free dev mode
LLM_PROVIDER=""
LLM_API_KEY=""

# Optional: Google Places / Geocoding (used for real discovery)
# If not set, app falls back to URL seeds or the mock registry.
GOOGLE_MAPS_API_KEY=""

# Defaults are Swiss-first
GOOGLE_PLACES_REGION="ch"
GOOGLE_PLACES_LANGUAGE="de"
